<div id="sites-island" class="watch-island">
    {% if not sites %}
        <p class="empty-notice">No sites yet. Add one with the button above.</p>
    {% else %}
        <ul class="watch-grid">
            {% for site in sites %}
                {% set snap = latest[site.id] %}

                {% if not site.is_active %}
                    {% set status = "paused" %}
                {% elif snap is none %}
                    {% set status = "pending" %}
                {% elif snap.error %}
                    {% set status = "error" %}
                {% elif snap.changed %}
                    {% set status = "changed" %}
                {% else %}
                    {% set status = "ok" %}
                {% endif %}

                <li class="watch-card watch-card--{{ status }}">
                    <div class="watch-card__header">
                        <span class="watch-card__status" aria-hidden="true"></span>
                        <a href="{{ url_for('watcher.detail', site_id=site.id) }}"
                           class="watch-card__name">{{ site.name }}</a>
                    </div>

                    <a href="{{ site.url }}"
                       class="watch-card__url"
                       target="_blank"
                       rel="noopener noreferrer">{{ site.url }}</a>

                    <div class="watch-card__timeline" aria-label="Last 24 hours">
                        {% for bucket in timeline[site.id] %}
                            {% if bucket is none %}
                                {% set lvl = "empty" %}
                            {% elif bucket == 0 %}
                                {% set lvl = "lvl-0" %}
                            {% elif bucket == 1 %}
                                {% set lvl = "lvl-1" %}
                            {% elif bucket == 2 %}
                                {% set lvl = "lvl-2" %}
                            {% else %}
                                {% set lvl = "lvl-3" %}
                            {% endif %}
                            {% set h_near = 23 - loop.index0 %}
                            {% set h_far = 24 - loop.index0 %}
                            {% if h_near == 0 %}
                                {% set time_label = "last hour" %}
                            {% else %}
                                {% set time_label = h_near ~ "-" ~ h_far ~ "h ago" %}
                            {% endif %}
                            {% if bucket is none %}
                                {% set tip = "No data · " ~ time_label %}
                            {% elif bucket == 0 %}
                                {% set tip = "No changes · " ~ time_label %}
                            {% elif bucket == 1 %}
                                {% set tip = "1 change · " ~ time_label %}
                            {% else %}
                                {% set tip = bucket ~ " changes · " ~ time_label %}
                            {% endif %}
                            <span class="tl-bar tl-bar--{{ lvl }}" data-tooltip="{{ tip }}"></span>
                        {% endfor %}
                    </div>

                    <dl class="watch-card__meta">
                        <div class="watch-card__meta-item">
                            <dt>Checked</dt>
                            <dd>
                                {{ site.last_checked_at | timeago }}
                            </dd>
                        </div>
                        <div class="watch-card__meta-item">
                            <dt>Changed</dt>
                            <dd>
                                {{ site.last_changed_at | timeago }}
                            </dd>
                        </div>
                    </dl>

                    <div class="watch-card__actions">
                        <form method="post"
                              action="{{ url_for('watcher.toggle', site_id=site.id) }}">
                            <button type="submit" class="btn--ghost btn--sm">
                                {% if site.is_active %}
                                    <i class="fa-solid fa-pause" aria-hidden="true"></i> Pause
                                {% else %}
                                    <i class="fa-solid fa-play" aria-hidden="true"></i> Resume
                                {% endif %}
                            </button>
                        </form>
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
