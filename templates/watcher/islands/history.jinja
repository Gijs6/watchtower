<section class="check-history"
         id="history-island"
         hx-get="{{ url_for('watcher.history_island', site_id=site.id) }}"
         hx-trigger="every 10s"
         hx-swap="outerHTML">
    <h2>Change history</h2>

    {% if not snapshots %}
        <p class="empty-notice">No checks recorded yet.</p>
    {% else %}
        <ol class="check-history__list">
            {% for snap, count, oldest in snapshots %}
                <li class="check-history__entry {% if snap.error %}check-history__entry--error{% elif snap.changed %}check-history__entry--changed{% else %}check-history__entry--ok{% endif %}">
                    <div class="check-history__entry-header">
                        <span class="check-history__dot" aria-hidden="true"></span>
                        {% if count > 1 %}
                            <time class="check-history__time"
                                  datetime="{{ oldest.captured_at | to_iso }}">
                                {{ oldest.captured_at | strftime }}
                            </time>
                            <span class="check-history__time-sep" aria-hidden="true">-</span>
                            <time class="check-history__time"
                                  datetime="{{ snap.captured_at | to_iso }}">
                                {{ snap.captured_at | strftime }}
                            </time>
                        {% else %}
                            <time class="check-history__time"
                                  datetime="{{ snap.captured_at | to_iso }}">
                                {{ snap.captured_at | strftime }}
                            </time>
                        {% endif %}
                        <span class="check-history__badge">
                            {% if snap.error %}
                                <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> Error
                            {% elif snap.changed %}
                                <i class="fa-solid fa-bolt" aria-hidden="true"></i> Changed
                            {% else %}
                                <i class="fa-solid fa-check" aria-hidden="true"></i> No change
                                {% if count > 1 %}&times;{{ count }}{% endif %}
                            {% endif %}
                        </span>
                    </div>

                    {% if snap.error %}
                        <p class="check-history__error-msg">{{ snap.error }}</p>
                    {% elif snap.changed and snap.diff_snippet %}
                        <details class="diff-view">
                            <summary class="diff-view__toggle">
                                <i class="fa-solid fa-fw fa-chevron-right diff-view__toggle-icon--closed"
                                   aria-hidden="true"></i><i class="fa-solid fa-fw fa-chevron-down diff-view__toggle-icon--open"
   aria-hidden="true"></i> Show diff
                            </summary>
                            <pre class="diff-view__code">{{ snap.diff_snippet | diff_html }}</pre>
                        </details>
                    {% endif %}
                </li>
            {% endfor %}
        </ol>
    {% endif %}
</section>
