{% extends "base.jinja" %}

{% block title %}Settings{% endblock %}

{% block content %}
    <div class="page-hero">
        <h1>
            <i class="fa-solid fa-gear" aria-hidden="true"></i> Settings
        </h1>
    </div>

    <section class="config-section">
        <h2>Notifications</h2>
        <form method="post"
              action="{{ url_for('watcher.settings_save') }}"
              class="config-section__form">
            <div class="config-section__fields">
                <div class="form-field">
                    <label for="discord_webhook">Discord webhook URL</label>
                    <input type="url"
                           id="discord_webhook"
                           name="discord_webhook"
                           value="{{ webhook }}"
                           placeholder="https://discord.com/api/webhooks/..." />
                    <p class="form-field__hint">Watchtower will send a message to this webhook when a monitored page changes.</p>
                </div>
            </div>
            <div class="config-section__actions">
                <button type="submit">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i> Save
                </button>
            </div>
        </form>
    </section>
{% endblock %}
