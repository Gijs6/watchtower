{% extends "base.jinja" %}

{% block title %}Add site{% endblock %}

{% block content %}
    <nav class="page-breadcrumb" aria-label="Breadcrumb">
        <a href="{{ url_for('watcher.index') }}" class="page-breadcrumb__link">
            <i class="fa-solid fa-home" aria-hidden="true"></i> Dashboard
        </a>
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
        <span>Add site</span>
    </nav>

    <div class="page-hero">
        <h1>
            <i class="fa-solid fa-plus" aria-hidden="true"></i> Add site
        </h1>
    </div>

    <section class="config-section">
        <form method="post"
              action="{{ url_for('watcher.add') }}"
              class="config-section__form">
            <div class="config-section__fields">
                <div class="form-field">
                    <label for="site-name">Name</label>
                    <input type="text"
                           id="site-name"
                           name="name"
                           placeholder="Auto-generated from URL"
                           value="{{ name or '' }}" />
                </div>
                <div class="form-field">
                    <label for="site-url">URL</label>
                    <input type="url"
                           id="site-url"
                           name="url"
                           placeholder="https://example.com"
                           value="{{ url or '' }}"
                           required />
                </div>
                <div class="form-field">
                    <label for="site-interval">Check interval (seconds)</label>
                    <input type="number"
                           id="site-interval"
                           name="check_interval"
                           value="{{ interval or 300 }}"
                           min="10"
                           max="86400" />
                </div>
            </div>
            <div class="config-section__actions">
                <button type="submit">
                    <i class="fa-solid fa-plus" aria-hidden="true"></i> Add
                </button>
            </div>
        </form>
    </section>
{% endblock %}
