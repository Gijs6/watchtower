{% extends "base.jinja" %}

{% block title %}{{ site.name }}{% endblock %}

{% block content %}
    <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="{{ url_for('watcher.index') }}">
            <i class="fa-solid fa-home" aria-hidden="true"></i> Dashboard
        </a>
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
        <span>{{ site.name }}</span>
    </nav>

    <div class="page-heading">
        <h1>{{ site.name }}</h1>
        <div class="actions">
            <form method="post"
                  action="{{ url_for('watcher.delete', site_id=site.id) }}"
                  onsubmit="return confirm('Remove {{ site.name }}?')">
                <button type="submit" class="danger">
                    <i class="fa-solid fa-trash" aria-hidden="true"></i> Remove
                </button>
            </form>
        </div>
    </div>

    <section class="settings-card">
        <h2>Site settings</h2>
        <form method="post"
              action="{{ url_for('watcher.update', site_id=site.id) }}"
              class="settings-form">
            <div class="settings-fields">
                <div class="field">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" value="{{ site.name }}" required />
                </div>
                <div class="field">
                    <label for="url">URL</label>
                    <input type="url" id="url" name="url" value="{{ site.url }}" required />
                </div>
                <div class="field">
                    <label for="check_interval">Interval (s)</label>
                    <input type="number"
                           id="check_interval"
                           name="check_interval"
                           value="{{ site.check_interval }}"
                           min="60"
                           max="86400" />
                </div>
            </div>
            <div class="form-actions">
                <button type="submit">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i> Save
                </button>
            </div>
        </form>
    </section>

    <section class="history-section">
        <h2>Change history</h2>

        {% if not snapshots %}
            <p class="is-empty">No checks recorded yet.</p>
        {% else %}
            <ol class="history-list">
                {% for snap in snapshots %}
                    <li class="history-entry {% if snap.error %}is-error{% elif snap.changed %}is-changed{% else %}is-ok{% endif %}">
                        <div class="history-entry-header">
                            <span class="history-dot" aria-hidden="true"></span>
                            <time class="history-time" datetime="{{ snap.captured_at | to_iso }}">
                                {{ snap.captured_at | strftime }}
                            </time>
                            <span class="history-badge">
                                {% if snap.error %}
                                    <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> Error
                                {% elif snap.changed %}
                                    <i class="fa-solid fa-bolt" aria-hidden="true"></i> Changed
                                {% else %}
                                    <i class="fa-solid fa-check" aria-hidden="true"></i> No change
                                {% endif %}
                            </span>
                        </div>

                        {% if snap.error %}
                            <p class="history-error">{{ snap.error }}</p>
                        {% elif snap.changed and snap.diff_snippet %}
                            <details class="diff-details">
                                <summary>Show diff</summary>
                                <pre class="diff-block">{{ snap.diff_snippet | diff_html }}</pre>
                            </details>
                        {% endif %}
                    </li>
                {% endfor %}
            </ol>
        {% endif %}
    </section>
{% endblock %}
