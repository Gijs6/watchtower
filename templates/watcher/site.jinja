{% extends "base.jinja" %}

{% block title %}{{ site.name }}{% endblock %}

{% block content %}
    <nav class="page-breadcrumb" aria-label="Breadcrumb">
        <a href="{{ url_for('watcher.index') }}" class="page-breadcrumb__link">
            <i class="fa-solid fa-home" aria-hidden="true"></i> Dashboard
        </a>
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
        <span>{{ site.name }}</span>
    </nav>

    <div class="page-hero">
        <h1>{{ site.name }}</h1>
        <div class="page-hero__actions">
            <form method="post"
                  action="{{ url_for('watcher.delete', site_id=site.id) }}"
                  onsubmit="return confirm('Remove {{ site.name }}?')">
                <button type="submit" class="btn--danger">
                    <i class="fa-solid fa-trash" aria-hidden="true"></i> Remove
                </button>
            </form>
        </div>
    </div>

    <section class="config-section">
        <h2>Site settings</h2>
        <form method="post"
              action="{{ url_for('watcher.update', site_id=site.id) }}"
              class="config-section__form">
            <div class="config-section__fields">
                <div class="form-field">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" value="{{ site.name }}" required />
                </div>
                <div class="form-field">
                    <label for="url">URL</label>
                    <input type="url" id="url" name="url" value="{{ site.url }}" required />
                </div>
                <div class="form-field">
                    <label for="check_interval">Interval (s)</label>
                    <input type="number"
                           id="check_interval"
                           name="check_interval"
                           value="{{ site.check_interval }}"
                           min="10"
                           max="86400" />
                </div>
            </div>
            <div class="config-section__actions">
                <button type="submit">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i> Save
                </button>
            </div>
        </form>
    </section>

    {% include "watcher/islands/history.jinja" %}

{% endblock %}
