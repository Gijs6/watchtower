{% extends "skeleton.jinja" %}

{% macro nav_item(endpoint, name) %}
    <a href="{{ url_for(endpoint) }}"
       class="app-nav__link{% if request.endpoint == endpoint %} app-nav__link--active{% endif %}">{{ name | safe }}</a>
{% endmacro %}

{% block body_content %}
    <header class="app-header">
        <a href="{{ url_for('index') }}" class="app-header__brand">
            <i class="fa-solid fa-tower-observation" aria-hidden="true"></i> Watchtower
        </a>
    </header>

    <div class="app-layout">
        <aside class="app-layout__sidebar">
            <nav class="app-nav" aria-label="Main navigation">
                <ul class="app-nav__list">
                    <li class="app-nav__item">
                        {{ nav_item('watcher.index', '<i class="fa-solid fa-fw fa-home" aria-hidden="true"></i> Dashboard') }}
                    </li>
                    <li class="app-nav__item">
                        {{ nav_item('watcher.settings', '<i class="fa-solid fa-fw fa-gear" aria-hidden="true"></i> Settings' + ('' if discord_webhook_set else ' <span class="app-nav__warning" data-tooltip="No Discord webhook set - notifications won\'t be sent" data-tooltip-position="right"><i class="fa-solid fa-triangle-exclamation" aria-label="Notifications not configured" role="img"></i></span>')) }}
                    </li>
                </ul>
            </nav>

            <form method="post" action="{{ url_for('logout') }}">
                <button type="submit" class="app-nav__signout">
                    <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i> Sign out
                </button>
            </form>
        </aside>

        <main class="app-layout__content">
            {% block content %}{% endblock %}
        </main>
    </div>
{% endblock %}
